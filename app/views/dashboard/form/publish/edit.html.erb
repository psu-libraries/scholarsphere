<div class="container">
  <div class="row">
    <div class="col" data-controller="unsaved-changes" data-unsaved-changes-prompt="<%= t 'dashboard.form.unsaved_changes_prompt' %>">
      <h1 class="text-center mb-4 h4"><%= t("dashboard.form.heading.#{param_key}.edit") %></h1>

      <%= render FormTabsComponent.new(resource: @resource, current_controller: controller_name) %>

      <div class="tab-content">
<div class="tab-pane active show"
     data-controller="open-access-version"
     data-open-access-version-id="<%= @resource.id %>"
     data-open-access-version-accepted-version-rights="<%= @permissions.licence('acceptedVersion') %>"
     data-open-access-version-published-version-rights="<%= @permissions.licence('publishedVersion') %>"

     data-open-access-version-accepted-version-statement="<%= @permissions.set_statement('acceptedVersion') %>"
     data-open-access-version-published-version-statement="<%= @permissions.set_statement('publishedVersion') %>"

     data-open-access-version-accepted-version-embargo="<%= @permissions.embargo_end_date('acceptedVersion') %>"
     data-open-access-version-published-version-embargo="<%= @permissions.embargo_end_date('publishedVersion') %>"
     
     data-open-access-version-current-version="<%= @current_version || 'acceptedVersion' %>"
     data-open-access-version-other-version="<%= @other_version %>"
     data-open-access-version-versions-found="<%= @permissions.versions_found?.to_json %>"
     data-open-access-version-not-found-message="<%= t('dashboard.works.edit.open_access_version.permissions_not_found') %>"
  data-open-access-version-other-message="<%= t('dashboard.works.edit.open_access_version.other_version_preferred', this_version: '__THIS__', other_version: '__OTHER__') %>">

          <%= form_with(
                model: @resource,
                url: dashboard_form_publish_path(@resource),
                local: true,
                id: 'file-uploader',
                data: {
                  target: 'unsaved-changes.form'
                }
              ) do |form| %>

            <%= render FormErrorMessageComponent.new(
                  form: form,
                  heading: t('.error_message', error: pluralize(form.object.errors.count, 'issue'))
                ) %>

            <%= render 'dashboard/form/type/work_version_fields', form: form, work_type_disabled: true %>
            <%= render "dashboard/form/details/#{@resource.form_partial}_fields", form: form, selected_version: @resource.open_access_version %>

            <% if deposit_pathway.instrument? %>
              <%= render 'dashboard/form/contributors/instrument_work_version_fields', form: form %>
            <% else %>
              <%= render 'dashboard/form/contributors/creators', form: form, resource_klass: 'work_version' %>
            <% end %>
            <%= render 'dashboard/form/contributors/contributors', form: form %>

            <div class="form-wrapper form-wrapper--wide">
              <div class="keyline keyline--left mb-3">
                <h4><%= t '.files' %></h4>
              </div>
            </div>
            <% if form.object.file_version_memberships.any? %>
              <%= render 'dashboard/form/files/uploaded_file_list', work_version: form.object %>
            <% end %>

            <% if @resource.open_access %>
              <div class="form-wrapper form-wrapper--wide">
                <div class="keyline keyline--left mb-3">
                  <h4><%= t '.version' %></h4>
                </div>
              </div>
              <%= render 'open_access_version', form: form %>
            <% end %>

            <div class="form-wrapper form-wrapper--wide">
              <div class="keyline keyline--left mb-3">
                <h4><%= t '.publishing_details' %></h4>
              </div>
            </div>
            <%= render 'fields', form: form %>

            <%= render 'dashboard/form/shared/action_footer',
                       form: form,
                       primary_action: form_should_publish? ? :publish : :finish %>

          <% end %>

        </div>
      </div>
    </div>
</div>
