<%= render 'dashboard/form/details/common_work_version_required_fields', form: form %>

<% if @resource.open_access_upload %>
  <% form.object.publisher_statement = @permissions&.publisher_statement(@resource.open_access_version) %>
<% end %>
<div class="form-wrapper">
  <%= render 'form_fields/text', form: form, attribute: :subtitle %>
  <%= render 'form_fields/multi_text', form: form, attribute: :publisher %>
<%= render 'form_fields/text_area',
           form: form,
           attribute: :publisher_statement,
           data: { target: 'open-access-version.publisherStatement' },
           readonly: @resource.open_access_upload && !current_user.admin? %>
  <%= render 'form_fields/multi_text', form: form,
                                       attribute: :identifier,
                                       readonly: @resource.imported_metadata_from_rmd? && !current_user.admin? %>
  <%= render 'dashboard/form/details/common_work_version_optional_fields', form: form %>
</div>
